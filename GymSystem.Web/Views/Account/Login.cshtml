@model GymSystem.Web.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign in — Gym System</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #f5f5f5;
        }

        .login-card {
            max-width: 420px;
            margin: 100px auto;
            border-radius: 12px;
            box-shadow: 0 2px 16px rgba(0,0,0,.08);
        }

        .login-header {
            background: #1a1a2e;
            color: #fff;
            border-radius: 12px 12px 0 0;
            padding: 28px 32px 20px;
        }

            .login-header h1 {
                font-size: 1.4rem;
                font-weight: 600;
                margin: 0;
            }

            .login-header p {
                font-size: .85rem;
                opacity: .7;
                margin: 4px 0 0;
            }

        .login-body {
            padding: 28px 32px 32px;
            background: #fff;
            border-radius: 0 0 12px 12px;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-header">
            <h1>Gym Management</h1>
            <p>Sign in to your account</p>
        </div>
        <div class="login-body">

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" style="display:none"></div>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger py-2 mb-3">
                        <span asp-validation-summary="ModelOnly"></span>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="admin@gym.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold">Password</label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                </div>

                <button type="submit" class="btn w-100 text-white"
                        style="background:#1a1a2e; padding: 10px;">
                    Sign in
                </button>
            </form>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
@using GymSystem.Web.ViewModels.Dashboard;
@model DashboardViewModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Dashboard</h4>
    <span class="text-muted small">12/5/2026</span>
</div>

<!-- Stats cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted small mb-1">Total Members</p>
                <h3 class="mb-0 fw-bold">@Model.TotalMembers</h3>
                <a asp-controller="Members" asp-action="Index"
                   class="text-decoration-none small">View all</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted small mb-1">Active Subscriptions</p>
                <h3 class="mb-0 fw-bold text-success">14</h3>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted small mb-1">Today's Check-ins</p>
                <h3 class="mb-0 fw-bold text-primary">25</h3>
                <a 
                   class="text-decoration-none small">View attendance</a>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted small mb-1">Total Classes</p>
                <h3 class="mb-0 fw-bold text-info">17</h3>
                <a 
                   class="text-decoration-none small">Manage classes</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">

    <!-- Expiring subscriptions -->
